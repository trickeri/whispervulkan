# Copy to config.env and edit for this machine. Sourced by whispervulkan.sh.
# config.env is gitignored (machine-specific paths).

# Path to the Vulkan-built whisper-server binary (rpath-linked — keep it in its build dir).
#WHISPER_SERVER_BIN="$HOME/programming/whisper.cpp/build/bin/whisper-server"

# Model file (large-v3-turbo f16 ~1.6 GB). Fetch with ./fetch-model.sh.
#WV_MODEL="$HOME/programming/whisper.cpp/models/ggml-large-v3-turbo.bin"

#WV_HOST="127.0.0.1"
#WV_PORT="48450"
#WV_THREADS="8"
#WV_LANG="en"        # 'auto' to auto-detect
